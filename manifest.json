{
  "author": "Italo Silva",
  "name": "Fullscreen!",
  "description": "Extension to make current page fullscreen.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": [
        "*://*/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab"]
}